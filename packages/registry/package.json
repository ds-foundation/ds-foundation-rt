{
  "name": "@ds/registry",
  "version": "0.2.0",
  "description": "Component registry — JSON schemas, MDX specs, Velite pipeline",
  "type": "module",
  "main": "./registry.json",
  "exports": {
    ".": "./registry.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "registry.json",
    "schemas/"
  ],
  "scripts": {
    "build": "velite build",
    "dev": "velite dev",
    "prepack": "cp .velite/registry.json ./registry.json",
    "typecheck": "echo 'registry: no TS sources to check (Velite pipeline)'",
    "clean": "rimraf .velite registry.json"
  },
  "dependencies": {
    "@ds/tokens": "*"
  },
  "devDependencies": {
    "velite": "^0.2.0",
    "typescript": "^5.7.0",
    "rimraf": "^6.0.0",
    "zod": "^3.23.0"
  }
}
